{
  "manifest_version": 3,
  "name": "Screen Recorder Extension",
  "version": "1.0",
  "description": "Record screen, camera, and mic in 4K with overlay",
  "permissions": ["activeTab", "storage", "offscreen", "downloads"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}